<Window x:Class="WPF_Staff_Admin.Views.Books.BookFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding FormTitle}"
        Height="1100" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📚"
                          FontSize="28"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
                <TextBlock Text="{Binding FormTitle}"
                          FontSize="22"
                          FontWeight="Bold"
                          Foreground="#263238"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

    
        <ScrollViewer Grid.Row="1"
                     VerticalScrollBarVisibility="Auto"
                     Padding="20">
            <StackPanel>
            
                <Border Background="White"
                       BorderBrush="#E0E0E0"
                       BorderThickness="1"
                       CornerRadius="5"
                       Padding="20"
                       Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Thông tin cơ bản"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  Foreground="#263238"
                                  Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                      Text="Tên sách *"
                                      FontSize="14"
                                      VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                   BorderBrush="#BDBDBD"
                                   BorderThickness="1"
                                   CornerRadius="3">
                                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                        Padding="10"
                                        FontSize="14"
                                        BorderThickness="0"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                      Text="ISBN"
                                      FontSize="14"
                                      VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                   BorderBrush="#BDBDBD"
                                   BorderThickness="1"
                                   CornerRadius="3">
                                <TextBox Text="{Binding Isbn, UpdateSourceTrigger=PropertyChanged}"
                                        Padding="10"
                                        FontSize="14"
                                        BorderThickness="0"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                      Text="Nhà xuất bản"
                                      FontSize="14"
                                      VerticalAlignment="Center"/>

                            <ComboBox Grid.Column="1"
                                     ItemsSource="{Binding Publishers}"
                                     SelectedValue="{Binding PublisherId}"
                                     DisplayMemberPath="PublisherName"
                                     SelectedValuePath="PublisherId"
                                     Padding="10"
                                     FontSize="14"/>

                            <TextBlock Grid.Column="3"
                                      Text="Năm xuất bản"
                                      FontSize="14"
                                      VerticalAlignment="Center"/>

                            <Border Grid.Column="4"
                                   BorderBrush="#BDBDBD"
                                   BorderThickness="1"
                                   CornerRadius="3">
                                <TextBox Text="{Binding PublicationYear, UpdateSourceTrigger=PropertyChanged}"
                                        Padding="10"
                                        FontSize="14"
                                        BorderThickness="0"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                      Text="Ngôn ngữ"
                                      FontSize="14"
                                      VerticalAlignment="Center"/>

                            <ComboBox Grid.Column="1"
                                     ItemsSource="{Binding Languages}"
                                     SelectedItem="{Binding Language}"
                                     Padding="10"
                                     FontSize="14"/>

                            <TextBlock Grid.Column="3"
                                      Text="Số trang"
                                      FontSize="14"
                                      VerticalAlignment="Center"/>

                            <Border Grid.Column="4"
                                   BorderBrush="#BDBDBD"
                                   BorderThickness="1"
                                   CornerRadius="3">
                                <TextBox Text="{Binding PageCount, UpdateSourceTrigger=PropertyChanged}"
                                        Padding="10"
                                        FontSize="14"
                                        BorderThickness="0"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                           Background="White"
                           BorderBrush="#E0E0E0"
                           BorderThickness="1"
                           CornerRadius="5"
                           Padding="20">
                        <StackPanel>
                            <TextBlock Text="Tác giả"
                                      FontSize="16"
                                      FontWeight="SemiBold"
                                      Foreground="#263238"
                                      Margin="0,0,0,10"/>

                            <Border BorderBrush="#E0E0E0"
                                   BorderThickness="1"
                                   CornerRadius="3"
                                   MaxHeight="200">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Authors}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding AuthorName}"
                                                         IsChecked="{Binding IsSelected}"
                                                         Margin="5"
                                                         FontSize="13"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                           Background="White"
                           BorderBrush="#E0E0E0"
                           BorderThickness="1"
                           CornerRadius="5"
                           Padding="20">
                        <StackPanel>
                            <TextBlock Text="Thể loại"
                                      FontSize="16"
                                      FontWeight="SemiBold"
                                      Foreground="#263238"
                                      Margin="0,0,0,10"/>

                            <Border BorderBrush="#E0E0E0"
                                   BorderThickness="1"
                                   CornerRadius="3"
                                   MaxHeight="200">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Categories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding CategoryName}"
                                                         IsChecked="{Binding IsSelected}"
                                                         Margin="5"
                                                         FontSize="13"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
                <Border Background="White"
                       BorderBrush="#E0E0E0"
                       BorderThickness="1"
                       CornerRadius="5"
                       Padding="20"
                       Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Số lượng, Giá"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  Foreground="#263238"
                                  Margin="0,0,0,15"/>

                        <!-- Total & Available Quantity -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Total Quantity -->
                            <TextBlock Grid.Column="0"
                                      Text="Tổng số lượng *"
                                      FontSize="14"
                                      VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                   BorderBrush="#BDBDBD"
                                   BorderThickness="1"
                                   CornerRadius="3">
                                <TextBox Text="{Binding TotalQuantity, UpdateSourceTrigger=PropertyChanged}"
                                        Padding="10"
                                        FontSize="14"
                                        BorderThickness="0"/>
                            </Border>

                            <!-- Available Quantity -->
                            <TextBlock Grid.Column="3"
                                      Text="Còn lại *"
                                      FontSize="14"
                                      VerticalAlignment="Center"/>

                            <Border Grid.Column="4"
                                   BorderBrush="#BDBDBD"
                                   BorderThickness="1"
                                   CornerRadius="3">
                                <TextBox Text="{Binding AvailableQuantity, UpdateSourceTrigger=PropertyChanged}"
                                        Padding="10"
                                        FontSize="14"
                                        BorderThickness="0"/>
                            </Border>
                        </Grid>

                        <!-- Price & Location -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Price -->
                            <TextBlock Grid.Column="0"
                                      Text="Giá (đ)"
                                      FontSize="14"
                                      VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                   BorderBrush="#BDBDBD"
                                   BorderThickness="1"
                                   CornerRadius="3">
                                <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"
                                        Padding="10"
                                        FontSize="14"
                                        BorderThickness="0"/>
                            </Border>

                            <!-- Location -->
                            <TextBlock Grid.Column="3"
                                      Text="Vị trí"
                                      FontSize="14"
                                      VerticalAlignment="Center"/>

                            <Border Grid.Column="4"
                                   BorderBrush="#BDBDBD"
                                   BorderThickness="1"
                                   CornerRadius="3">
                                <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                                        Padding="10"
                                        FontSize="14"
                                        BorderThickness="0"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White"
       BorderBrush="#E0E0E0"
       BorderThickness="1"
       CornerRadius="5"
       Padding="20">
                    <StackPanel>
                        <TextBlock Text="Hình ảnh, Mô tả"
                  FontSize="16"
                  FontWeight="SemiBold"
                  Foreground="#263238"
                  Margin="0,0,0,15"/>

                        <!-- Image Selection -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                      Text="Ảnh sách"
                      FontSize="14"
                      VerticalAlignment="Top"
                      Margin="0,10,0,0"/>

                            <StackPanel Grid.Column="1">

                                <Border BorderBrush="#E0E0E0"
                       BorderThickness="1"
                       CornerRadius="3"
                       Width="200"
                       Height="280"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,10"
                       Background="#F5F5F5">
                                    <Grid>

                                        <TextBlock Text="📖"
                                  FontSize="60"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="#BDBDBD">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSelectedImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Image Source="{Binding SelectedImagePath}"
                              Stretch="UniformToFill">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSelectedImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>

                                        <Border Background="White"
                               Opacity="0.9"
                               Visibility="{Binding IsUploadingImage, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel VerticalAlignment="Center"
                                       HorizontalAlignment="Center">
                                                <ProgressBar IsIndeterminate="True"
                                            Width="100"
                                            Height="3"
                                            Margin="0,0,0,10"/>
                                                <TextBlock Text="Đang upload..."
                                          FontSize="12"
                                          HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📁 Chọn ảnh"
                           Command="{Binding BrowseImageCommand}"
                           Background="#2196F3"
                           Foreground="White"
                           BorderThickness="0"
                           Padding="15,8"
                           FontSize="13"
                           Margin="0,0,10,0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="3"
                                                   Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1976D2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="❌ Xóa"
                           Command="{Binding ClearImageCommand}"
                           Background="#F44336"
                           Foreground="White"
                           BorderThickness="0"
                           Padding="15,8"
                           FontSize="13"
                           Visibility="{Binding HasSelectedImage, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="3"
                                                   Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#D32F2F"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                      Text="Mô tả"
                      FontSize="14"
                      VerticalAlignment="Top"
                      Margin="0,10,0,0"/>

                            <Border Grid.Column="1"
                   BorderBrush="#BDBDBD"
                   BorderThickness="1"
                   CornerRadius="3">
                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                        Padding="10"
                        FontSize="14"
                        BorderThickness="0"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        Height="100"
                        VerticalScrollBarVisibility="Auto"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White"
                       BorderBrush="#E0E0E0"
                       BorderThickness="1"
                       CornerRadius="5"
                       Padding="20">
                    
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          VerticalAlignment="Center"
                          FontSize="12"
                          Foreground="#757575">
                    <Run Text="*"/>
                    <Run Text="Trường bắt buộc"/>
                </TextBlock>

                <StackPanel Grid.Column="1"
                           Orientation="Horizontal">
                    <Button Content="Hủy"
                           Command="{Binding CancelCommand}"
                           Background="#757575"
                           Foreground="White"
                           BorderThickness="0"
                           Padding="25,10"
                           FontSize="14"
                           Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="5"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#616161"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="💾 Lưu"
                           Command="{Binding SaveCommand}"
                           Background="#4CAF50"
                           Foreground="White"
                           BorderThickness="0"
                           Padding="30,10"
                           FontSize="14">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="5"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#388E3C"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#BDBDBD"/>
                                        <Setter Property="Cursor" Value="No"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="0" Grid.RowSpan="3"
               Background="White"
               Opacity="0.9"
               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                            Width="200"
                            Height="4"
                            Margin="0,0,0,10"/>
                <TextBlock Text="Đang tải dữ liệu..."
                          FontSize="14"
                          HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.RowSpan="3"
               Background="White"
               Opacity="0.9"
               Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                            Width="200"
                            Height="4"
                            Margin="0,0,0,10"/>
                <TextBlock Text="Đang lưu..."
                          FontSize="14"
                          HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>