<Window x:Class="WPF_Staff_Admin.Views.Books.BookDetailView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Staff_Admin.Views.Books"
        mc:Ignorable="d"
        Title="Chi tiết sách"
        Height="1000" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="5"
                Padding="20"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="📚"
                          FontSize="32"
                          VerticalAlignment="Center"
                          Margin="0,0,15,0"/>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Book.Title}"
                              FontSize="24"
                              FontWeight="Bold"
                              Foreground="#263238"
                              TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Book.Isbn, StringFormat='ISBN: {0}'}"
                              FontSize="13"
                              Foreground="#757575"
                              Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                     VerticalScrollBarVisibility="Auto">
            <Grid>
                <Border Background="White"
                       CornerRadius="5"
                       Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                      
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                   Background="#F5F5F5"
                                   BorderBrush="#E0E0E0"
                                   BorderThickness="1"
                                   CornerRadius="5"
                                   Height="280"
                                   Margin="0,0,20,0">
                                <Grid>
                                    <TextBlock Text="📖"
                                              FontSize="80"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="#BDBDBD">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Book.ImageUrl, Converter={StaticResource StringToVisibilityConverter}}" Value="Visible">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Image Source="{Binding Book.ImageUrl}"
                                          Stretch="UniformToFill"
                                          Visibility="{Binding Book.ImageUrl, Converter={StaticResource StringToVisibilityConverter}}"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                                    <TextBlock Text="Tác giả"
                                              FontSize="12"
                                              Foreground="#757575"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding AuthorsDisplay}"
                                              FontSize="15"
                                              FontWeight="SemiBold"
                                              Foreground="#263238"
                                              TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                                    <TextBlock Text="Thể loại"
                                              FontSize="12"
                                              Foreground="#757575"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding CategoriesDisplay}"
                                              FontSize="15"
                                              Foreground="#263238"
                                              TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Margin="0,0,0,15">
                                    <TextBlock Text="Nhà xuất bản"
                                              FontSize="12"
                                              Foreground="#757575"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding Book.PublisherName}"
                                              FontSize="15"
                                              Foreground="#263238"/>
                                </StackPanel>

                                <StackPanel Grid.Row="3" Margin="0,0,0,15">
                                    <TextBlock Text="Năm xuất bản"
                                              FontSize="12"
                                              Foreground="#757575"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding Book.PublicationYear}"
                                              FontSize="15"
                                              Foreground="#263238"/>
                                </StackPanel>

                                <StackPanel Grid.Row="4" Margin="0,0,0,15">
                                    <TextBlock Text="Ngôn ngữ"
                                              FontSize="12"
                                              Foreground="#757575"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding Book.Language}"
                                              FontSize="15"
                                              Foreground="#263238"/>
                                </StackPanel>

                                <StackPanel Grid.Row="5" Margin="0,0,0,15">
                                    <TextBlock Text="Số trang"
                                              FontSize="12"
                                              Foreground="#757575"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding Book.PageCount}"
                                              FontSize="15"
                                              Foreground="#263238"/>
                                </StackPanel>

                                <StackPanel Grid.Row="6">
                                    <TextBlock Text="Vị trí"
                                              FontSize="12"
                                              Foreground="#757575"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding Book.Location}"
                                              FontSize="15"
                                              Foreground="#263238"/>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <Border Grid.Row="1"
                               Height="1"
                               Background="#E0E0E0"
                               Margin="0,0,0,20"/>

                        <Grid Grid.Row="2" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                   Background="#E3F2FD"
                                   CornerRadius="5"
                                   Padding="15"
                                   Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="📊 Số lượng"
                                              FontSize="13"
                                              Foreground="#1976D2"
                                              FontWeight="SemiBold"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding QuantityInfo}"
                                              FontSize="18"
                                              FontWeight="Bold"
                                              Foreground="#0D47A1"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                   Background="#FFF3E0"
                                   CornerRadius="5"
                                   Padding="15"
                                   Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="💰 Giá bán"
                                              FontSize="13"
                                              Foreground="#F57C00"
                                              FontWeight="SemiBold"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding PriceDisplay}"
                                              FontSize="18"
                                              FontWeight="Bold"
                                              Foreground="#E65100"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="3"
                               Height="1"
                               Background="#E0E0E0"
                               Margin="0,0,0,20"/>

                        <StackPanel Grid.Row="4">
                            <TextBlock Text="Mô tả"
                                      FontSize="14"
                                      FontWeight="SemiBold"
                                      Foreground="#263238"
                                      Margin="0,0,0,10"/>

                            <TextBlock FontSize="13"
                                      Foreground="#616161"
                                      TextWrapping="Wrap"
                                      LineHeight="22">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Book.Description}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Book.Description}" Value="">
                                                <Setter Property="Text" Value="Chưa có mô tả"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Book.Description}" Value="{x:Null}">
                                                <Setter Property="Text" Value="Chưa có mô tả"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White"
                       Opacity="0.9"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center"
                               HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True"
                                    Width="200"
                                    Height="4"
                                    Margin="0,0,0,10"/>
                        <TextBlock Text="Đang tải..."
                                  FontSize="14"
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="5"
                Padding="20"
                Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                       Content="🗑️ Xóa sách"
                       Command="{Binding DeleteCommand}"
                       Background="#F44336"
                       Foreground="White"
                       BorderThickness="0"
                       Padding="20,10"
                       FontSize="14"
                       HorizontalAlignment="Left">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               CornerRadius="5"
                                               Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D32F2F"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel Grid.Column="1"
                           Orientation="Horizontal">
                    <Button Content="✏️ Chỉnh sửa"
                           Command="{Binding EditCommand}"
                           Background="#FF9800"
                           Foreground="White"
                           BorderThickness="0"
                           Padding="20,10"
                           FontSize="14"
                           Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="5"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F57C00"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Đóng"
                           Command="{Binding CloseCommand}"
                           Background="#757575"
                           Foreground="White"
                           BorderThickness="0"
                           Padding="20,10"
                           FontSize="14">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="5"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#616161"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
