<Window x:Class="WPF_Staff_Admin.Views.Borrowing.BorrowingDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Chi tiết phiếu mượn sách"
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="20">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📄"
                              FontSize="28"
                              VerticalAlignment="Center"
                              Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Chi tiết phiếu mượn sách"
                                  FontSize="20"
                                  FontWeight="Bold"
                                  Foreground="#263238"/>
                        <TextBlock FontSize="13" Foreground="#757575" Margin="0,3,0,0">
                            <Run Text="Mã phiếu:"/>
                            <Run Text="{Binding Ticket.TicketId, Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                <!-- Member Info -->
                <Border Background="White"
                       BorderBrush="#E0E0E0"
                       BorderThickness="1"
                       CornerRadius="5"
                       Padding="20"
                       Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Thông tin thành viên"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  Foreground="#263238"
                                  Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Name -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                      Text="Họ tên:"
                                      FontSize="13"
                                      Foreground="#757575"
                                      Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                      Text="{Binding Ticket.MemberName}"
                                      FontSize="13"
                                      FontWeight="SemiBold"
                                      Foreground="#263238"
                                      Margin="0,0,0,10"/>

                            <!-- Email -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                      Text="Email:"
                                      FontSize="13"
                                      Foreground="#757575"
                                      Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                      Text="{Binding Ticket.MemberEmail}"
                                      FontSize="13"
                                      Foreground="#263238"
                                      Margin="0,0,0,10"/>

                            <!-- Phone -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                      Text="Số điện thoại:"
                                      FontSize="13"
                                      Foreground="#757575"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                      Text="{Binding Ticket.MemberPhone}"
                                      FontSize="13"
                                      Foreground="#263238"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Borrowing Info -->
                <Border Background="White"
                       BorderBrush="#E0E0E0"
                       BorderThickness="1"
                       CornerRadius="5"
                       Padding="20"
                       Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Thông tin mượn sách"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  Foreground="#263238"
                                  Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Borrow Date -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ngày mượn"
                                          FontSize="11"
                                          Foreground="#757575"
                                          Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Ticket.BorrowDateDisplay}"
                                          FontSize="16"
                                          FontWeight="Bold"
                                          Foreground="#2196F3"/>
                            </StackPanel>

                            <!-- Due Date -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Hạn trả"
                                          FontSize="11"
                                          Foreground="#757575"
                                          Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Ticket.DueDateDisplay}"
                                          FontSize="16"
                                          FontWeight="Bold"
                                          Foreground="#FF9800"/>
                            </StackPanel>

                            <!-- Total Books -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Tổng sách"
                                          FontSize="11"
                                          Foreground="#757575"
                                          Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Ticket.TotalBooks}"
                                          FontSize="16"
                                          FontWeight="Bold"
                                          Foreground="#4CAF50"/>
                            </StackPanel>

                            <!-- Total Fines -->
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Tiền phạt"
                                          FontSize="11"
                                          Foreground="#757575"
                                          Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Ticket.FinesDisplay}"
                                          FontSize="16"
                                          FontWeight="Bold"
                                          Foreground="#F44336"/>
                            </StackPanel>
                        </Grid>

                        <!-- Librarian & Notes -->
                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Librarian -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                      Text="Thủ thư:"
                                      FontSize="13"
                                      Foreground="#757575"
                                      Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                      Text="{Binding Ticket.LibrarianName}"
                                      FontSize="13"
                                      Foreground="#263238"
                                      Margin="0,0,0,10"/>

                            <!-- Notes -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                      Text="Ghi chú:"
                                      FontSize="13"
                                      Foreground="#757575"
                                      VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                      Text="{Binding Ticket.Notes}"
                                      FontSize="13"
                                      Foreground="#263238"
                                      TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Books List -->
                <Border Background="White"
                       BorderBrush="#E0E0E0"
                       BorderThickness="1"
                       CornerRadius="5"
                       Padding="20">
                    <StackPanel>
                        <TextBlock Text="Danh sách sách"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  Foreground="#263238"
                                  Margin="0,0,0,15"/>

                        <ItemsControl ItemsSource="{Binding Ticket.Details}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FAFAFA"
                                           BorderBrush="#E0E0E0"
                                           BorderThickness="1"
                                           CornerRadius="5"
                                           Padding="15"
                                           Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Book Image -->
                                            <Border Grid.Column="0"
                                                   Width="80"
                                                   Height="110"
                                                   BorderBrush="#E0E0E0"
                                                   BorderThickness="1"
                                                   CornerRadius="3"
                                                   Margin="0,0,15,0"
                                                   Background="#F5F5F5">
                                                <Image Source="{Binding BookImageUrl}"
                                                      Stretch="UniformToFill"/>
                                            </Border>

                                            <!-- Book Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding BookTitle}"
                                                          FontWeight="SemiBold"
                                                          FontSize="14"
                                                          TextWrapping="Wrap"
                                                          Foreground="#263238"
                                                          Margin="0,0,0,5"/>

                                                <TextBlock FontSize="12" Foreground="#757575" Margin="0,0,0,3">
                                                    <Run Text="ISBN:"/>
                                                    <Run Text="{Binding BookIsbn}"/>
                                                </TextBlock>

                                                <TextBlock FontSize="12" Foreground="#757575" Margin="0,0,0,3">
                                                    <Run Text="Tác giả:"/>
                                                    <Run Text="{Binding Authors}"/>
                                                </TextBlock>

                                                <TextBlock FontSize="12" Foreground="#757575" Margin="0,0,0,8">
                                                    <Run Text="Giá:"/>
                                                    <Run Text="{Binding BookPrice, StringFormat='{}{0:N0} đ'}" FontWeight="SemiBold"/>
                                                </TextBlock>

                                                <!-- Return Date -->
                                                <Border Background="#E8F5E9"
                                                       CornerRadius="3"
                                                       Padding="8,4"
                                                       HorizontalAlignment="Left"
                                                       Visibility="{Binding ReturnDate, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock FontSize="11" Foreground="#388E3C">
                                                        <Run Text="Đã trả:"/>
                                                        <Run Text="{Binding ReturnDateDisplay}" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Overdue Info -->
                                                <Border Background="#FFEBEE"
                                                       CornerRadius="3"
                                                       Padding="8,4"
                                                       Margin="0,5,0,0"
                                                       HorizontalAlignment="Left"
                                                       Visibility="{Binding IsOverdue, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding OverdueInfo}"
                                                             FontSize="11"
                                                             Foreground="#D32F2F"
                                                             FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>

                                            <!-- Status Badge -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <Border Background="{Binding StatusBackground}"
                                                       CornerRadius="12"
                                                       Padding="12,6">
                                                    <TextBlock Text="{Binding StatusDisplay}"
                                                             FontWeight="SemiBold"
                                                             FontSize="12"
                                                             Foreground="{Binding StatusForeground}"
                                                             TextAlignment="Center"/>
                                                </Border>

                                                <!-- Fines -->
                                                <Border Background="#FFEBEE"
                                                       CornerRadius="3"
                                                       Padding="8,4"
                                                       Margin="0,8,0,0"
                                                       Visibility="{Binding TotalFineAmount, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock FontSize="11" Foreground="#D32F2F" TextAlignment="Center">
                                                        <Run Text="Phạt:"/>
                                                        <Run Text="{Binding TotalFineAmount, Mode=OneWay, StringFormat='{}{0:N0} đ'}" FontWeight="Bold"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="20">
            <Button Content="Đóng"
                   Command="{Binding CloseCommand}"
                   Background="#757575"
                   Foreground="White"
                   BorderThickness="0"
                   Padding="30,10"
                   FontSize="14"
                   HorizontalAlignment="Right"
                   Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                           CornerRadius="5"
                                           Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#616161"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Border>
    </Grid>
</Window>