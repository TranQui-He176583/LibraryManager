<Window x:Class="WPF_Staff_Admin.Views.Borrowing.ReturnBookDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Trả sách"
        Height="650" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="20">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📥"
                              FontSize="28"
                              VerticalAlignment="Center"
                              Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Trả sách"
                                  FontSize="20"
                                  FontWeight="Bold"
                                  Foreground="#263238"/>
                        <TextBlock FontSize="13" Foreground="#757575" Margin="0,3,0,0">
                            <Run Text="Phiếu #"/>
                            <Run Text="{Binding Ticket.TicketId}" FontWeight="SemiBold"/>
                            <Run Text=" - "/>
                            <Run Text="{Binding Ticket.MemberName}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Selected Count Badge -->
                <Border Background="#FF9800"
       CornerRadius="15"
       Padding="12,6"
       HorizontalAlignment="Right">
                    <TextBlock Foreground="White" FontSize="13" FontWeight="SemiBold">
        <Run Text="Đã chọn: "/>
        <Run Text="{Binding TotalSelectedBooks, Mode=OneWay}"/> 
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Return Date & Notes -->
            <Border Grid.Row="0"
                   Background="White"
                   BorderBrush="#E0E0E0"
                   BorderThickness="1"
                   CornerRadius="5"
                   Padding="15"
                   Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Return Date -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Ngày trả"
                                  FontSize="12"
                                  Foreground="#757575"
                                  Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding ReturnDate}"
                                   Width="150"
                                   Padding="8"
                                   FontSize="13"/>
                    </StackPanel>

                    <!-- Notes -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Ghi chú (tùy chọn)"
                                  FontSize="12"
                                  Foreground="#757575"
                                  Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                Padding="8"
                                FontSize="13"
                                Height="40"
                                VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Books List -->
            <Border Grid.Row="1"
                   Background="White"
                   BorderBrush="#E0E0E0"
                   BorderThickness="1"
                   CornerRadius="5"
                   Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Chọn sách cần trả:"
                                  FontSize="14"
                                  FontWeight="SemiBold"
                                  Foreground="#263238"
                                  Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding ReturningBooks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FAFAFA"
                                           BorderBrush="#E0E0E0"
                                           BorderThickness="1"
                                           CornerRadius="5"
                                           Padding="12"
                                           Margin="0,0,0,10"
                                           Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Checkbox -->
                                            <CheckBox Grid.Column="0"
                                                     IsChecked="{Binding IsSelected}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,12,0"/>

                                            <!-- Book Image -->
                                            <Border Grid.Column="1"
                                                   Width="60"
                                                   Height="80"
                                                   BorderBrush="#E0E0E0"
                                                   BorderThickness="1"
                                                   CornerRadius="3"
                                                   Margin="0,0,12,0"
                                                   Background="#F5F5F5">
                                                <Image Source="{Binding BookImageUrl}"
                                                      Stretch="UniformToFill"/>
                                            </Border>

                                            <!-- Book Info -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding BookTitle}"
                                                          FontWeight="SemiBold"
                                                          FontSize="13"
                                                          TextWrapping="Wrap"
                                                          Foreground="#263238"
                                                          Margin="0,0,0,4"/>

                                                <TextBlock FontSize="11" Foreground="#757575" Margin="0,0,0,2">
                                                    <Run Text="ISBN:"/>
                                                    <Run Text="{Binding BookIsbn}"/>
                                                </TextBlock>

                                                <TextBlock FontSize="11" Foreground="#757575" Margin="0,0,0,2">
                                                    <Run Text="Tác giả:"/>
                                                    <Run Text="{Binding Authors}"/>
                                                </TextBlock>

                                                <!-- Overdue Warning -->
                                                <Border Background="#FFEBEE"
                                                       CornerRadius="3"
                                                       Padding="6,3"
                                                       Margin="0,4,0,0"
                                                       HorizontalAlignment="Left"
                                                       Visibility="{Binding IsOverdue, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding OverdueInfo}"
                                                             FontSize="10"
                                                             Foreground="#D32F2F"
                                                             FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>

                                            <!-- Status & Fine -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="12,0,0,0">
                                                <Border Background="{Binding StatusBackground}"
                                                       CornerRadius="10"
                                                       Padding="10,5"
                                                       Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding StatusDisplay}"
                                                             FontWeight="SemiBold"
                                                             FontSize="11"
                                                             Foreground="{Binding StatusForeground}"
                                                             TextAlignment="Center"/>
                                                </Border>

                                                <!-- Fine Amount -->
                                                <Border Background="#FFEBEE"
                                                       CornerRadius="3"
                                                       Padding="8,4"
                                                       Visibility="{Binding IsOverdue, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock FontSize="11" Foreground="#D32F2F" FontWeight="SemiBold" TextAlignment="Center">
                                                        <Run Text="Phạt:"/>
                                                        <Run Text="{Binding DaysOverdue}"/>
                                                        <Run Text="x 5k"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- No books message -->
                        <StackPanel VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0"
                                   Visibility="{Binding ReturningBooks.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="📚"
                                      FontSize="48"
                                      HorizontalAlignment="Center"
                                      Foreground="#BDBDBD"
                                      Margin="0,0,0,10"/>
                            <TextBlock Text="Không có sách nào cần trả"
                                      FontSize="14"
                                      Foreground="#757575"
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Info Box -->
            <Border Grid.Row="2"
                   Background="#E3F2FD"
                   BorderBrush="#2196F3"
                   BorderThickness="1"
                   CornerRadius="5"
                   Padding="12"
                   Margin="0,15,0,0">
                <TextBlock FontSize="12" Foreground="#1565C0">
                    <Run Text="ℹ️"/>
                    <Run Text="Chọn các sách cần trả và nhấn 'Xác nhận trả sách'. Nếu trả quá hạn, hệ thống sẽ tự động tính phạt."/>
                </TextBlock>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="20">
            <StackPanel Orientation="Horizontal"
                       HorizontalAlignment="Right">
                <!-- Cancel Button -->
                <Button Content="Hủy"
                       Command="{Binding CancelCommand}"
                       Background="#757575"
                       Foreground="White"
                       BorderThickness="0"
                       Padding="25,10"
                       FontSize="14"
                       Margin="0,0,10,0"
                       Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               CornerRadius="5"
                                               Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#616161"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Return Button -->
                <Button Content="📥 Xác nhận trả sách"
                       Command="{Binding ReturnCommand}"
                       Background="#FF9800"
                       Foreground="White"
                       BorderThickness="0"
                       Padding="30,10"
                       FontSize="14"
                       Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               CornerRadius="5"
                                               Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F57C00"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#BDBDBD"/>
                                    <Setter Property="Cursor" Value="No"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- Returning Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
               Background="White"
               Opacity="0.9"
               Visibility="{Binding IsReturning, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                            Width="200"
                            Height="4"
                            Margin="0,0,0,10"/>
                <TextBlock Text="Đang xử lý trả sách..."
                          FontSize="14"
                          HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>