<UserControl x:Class="WPF_Staff_Admin.Views.Users.UserListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_Staff_Admin.Views.Users"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    
    <Grid Background="#F9FAFB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="20" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="Quản lý Người dùng" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Quản lý thông tin độc giả và nhân viên trong hệ thống" Foreground="#6B7280" Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding AddUserCommand}" 
                        Content="+ Thêm Member mới" 
                        Background="#10B981" Foreground="White" 
                        Padding="15,10" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- Search & Filter Bar -->
        <Border Grid.Row="1" Margin="20,10" Padding="15" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <StackPanel Width="300" Margin="0,0,20,0">
                    <TextBlock Text="Tìm kiếm" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#374151"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Height="35" VerticalContentAlignment="Center" Padding="5"/>
                </StackPanel>

                <StackPanel Width="150" Margin="0,0,20,0">
                    <TextBlock Text="Vai trò" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#374151"/>
                    <ComboBox ItemsSource="{Binding RoleFilters}" 
                              SelectedItem="{Binding SelectedRoleFilter}" 
                              Height="35" VerticalContentAlignment="Center"/>
                </StackPanel>

                <Button Content="Làm mới" Command="{Binding RefreshCommand}" 
                        VerticalAlignment="Bottom" Height="35" Padding="20,0"/>
            </StackPanel>
        </Border>

        <!-- Data Grid -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <DataGrid ItemsSource="{Binding FilteredUsers}" 
                      SelectedItem="{Binding SelectedUser}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      Background="White" 
                      BorderThickness="1" BorderBrush="#E5E7EB"
                      RowHeight="40">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="UserID" Binding="{Binding UserId}" Width="60"/>
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="120"/>
                    <DataGridTextColumn Header="Họ và tên" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                    <DataGridTextColumn Header="Vai trò" Binding="{Binding Role}" Width="100"/>
                    <DataGridTextColumn Header="Hoạt động" Binding="{Binding IsActive}" Width="80"/>
                    <DataGridTextColumn Header="Hết hạn thẻ" Binding="{Binding MembershipExpiry, StringFormat=dd/MM/yyyy}" Width="100"/>
                    
                    <DataGridTemplateColumn Header="Thao tác" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Sửa" Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            Margin="2" Padding="5,2"/>
                                    <Button Content="Khóa/Mở" 
                                            Command="{Binding DataContext.ToggleStatusCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            Margin="2" Padding="5,2"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Loading Overlay -->
            <Border Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="10"/>
                    <TextBlock Text="Đang tải dữ liệu..." Margin="0,10,0,0" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
