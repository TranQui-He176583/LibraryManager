<Window x:Class="WPF_Staff_Admin.Views.Users.UserFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:WPF_Staff_Admin.Views.Users"
        mc:Ignorable="d" 
        Title="{Binding Title}" Height="600" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="White">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Tên đăng nhập" FontWeight="Bold" Margin="0,5"/>
                <TextBox Text="{Binding Username}" Height="30" IsReadOnly="{Binding IsEditMode}"/>

                <StackPanel Visibility="{Binding IsCreateMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Mật khẩu" FontWeight="Bold" Margin="0,5"/>
                    <PasswordBox x:Name="PassBox" Height="30" PasswordChanged="PassBox_PasswordChanged"/>
                </StackPanel>

                <TextBlock Text="Họ và tên *" FontWeight="Bold" Margin="0,5"/>
                <TextBox Text="{Binding FullName}" Height="30"/>

                <TextBlock Text="Email *" FontWeight="Bold" Margin="0,5"/>
                <TextBox Text="{Binding Email}" Height="30"/>

                <TextBlock Text="Số điện thoại" FontWeight="Bold" Margin="0,5"/>
                <TextBox Text="{Binding PhoneNumber}" Height="30"/>

                <TextBlock Text="Địa chỉ" FontWeight="Bold" Margin="0,5"/>
                <TextBox Text="{Binding Address}" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>

                <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Đặt lại mật khẩu (Để trống nếu không đổi)" FontWeight="Bold" Foreground="Red" Margin="0,5"/>
                    <PasswordBox x:Name="NewPassBox" Height="30" PasswordChanged="NewPassBox_PasswordChanged"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Hủy" Command="{Binding CancelCommand}" Width="80" Height="30" Margin="0,0,10,0"/>
            <Button Content="Lưu lại" Command="{Binding SaveCommand}" Width="80" Height="30" Background="#3B82F6" Foreground="White"/>
        </StackPanel>

        <Border Grid.RowSpan="3" Background="#80FFFFFF" Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Đang xử lý..." HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
