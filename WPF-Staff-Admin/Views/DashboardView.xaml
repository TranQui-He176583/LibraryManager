<UserControl x:Class="WPF_Staff_Admin.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_Staff_Admin.Views"
              mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
      
            <TextBlock FontSize="28"
                      FontWeight="Bold"
                      Foreground="#263238"
                      Margin="0,0,0,10">
                <Run Text="Xin chào, "/>
                <Run Text="{Binding UserFullName, Mode=OneWay}"/>
            </TextBlock>

            <TextBlock Text="Chào mừng bạn đến với Hệ thống Quản lý Thư viện"
                      FontSize="16"
                      Foreground="#607D8B"
                      Margin="0,0,0,30"/>

      
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

              
                <Border Grid.Column="0"
                       Background="#2196F3"
                       CornerRadius="10"
                       Margin="0,0,10,0"
                       Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📚"
                                  FontSize="36"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,10"/>
                        <TextBlock Text="Tổng số sách"
                                  FontSize="14"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  Opacity="0.9"/>
                        <TextBlock Text="{Binding TotalBooks}"
                                  FontSize="32"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

               
                <Border Grid.Column="1"
                       Background="#4CAF50"
                       CornerRadius="10"
                       Margin="0,0,10,0"
                       Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="✅"
                                  FontSize="36"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,10"/>
                        <TextBlock Text="Sách có sẵn"
                                  FontSize="14"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  Opacity="0.9"/>
                        <TextBlock Text="{Binding AvailableBooks}"
                                  FontSize="32"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

               
                <Border Grid.Column="2"
                       Background="#FF9800"
                       CornerRadius="10"
                       Margin="0,0,10,0"
                       Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📖"
                                  FontSize="36"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,10"/>
                        <TextBlock Text="Đang mượn"
                                  FontSize="14"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  Opacity="0.9"/>
                        <TextBlock Text="{Binding ActiveBorrowings}"
                                  FontSize="32"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

         
                <Border Grid.Column="3"
                       Background="#F44336"
                       CornerRadius="10"
                       Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="⚠️"
                                  FontSize="36"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,10"/>
                        <TextBlock Text="Quá hạn"
                                  FontSize="14"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  Opacity="0.9"/>
                        <TextBlock Text="{Binding OverdueBorrowings}"
                                  FontSize="32"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="Thao tác nhanh"
                      FontSize="20"
                      FontWeight="SemiBold"
                      Foreground="#263238"
                      Margin="0,40,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                       Height="100"
                       Margin="0,0,10,0"
                       Background="White"
                       BorderThickness="1"
                       BorderBrush="#E0E0E0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               BorderBrush="{TemplateBinding BorderBrush}"
                                               BorderThickness="{TemplateBinding BorderThickness}"
                                               CornerRadius="10">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="➕"
                                                         FontSize="32"
                                                         HorizontalAlignment="Center"
                                                         Margin="0,0,0,5"/>
                                                <TextBlock Text="Thêm sách mới"
                                                         FontSize="14"
                                                         Foreground="#263238"
                                                         HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="1"
                       Height="100"
                       Margin="0,0,10,0"
                       Background="White"
                       BorderThickness="1"
                       BorderBrush="#E0E0E0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               BorderBrush="{TemplateBinding BorderBrush}"
                                               BorderThickness="{TemplateBinding BorderThickness}"
                                               CornerRadius="10">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="📖"
                                                         FontSize="32"
                                                         HorizontalAlignment="Center"
                                                         Margin="0,0,0,5"/>
                                                <TextBlock Text="Mượn sách"
                                                         FontSize="14"
                                                         Foreground="#263238"
                                                         HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2"
                       Height="100"
                       Background="White"
                       BorderThickness="1"
                       BorderBrush="#E0E0E0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               BorderBrush="{TemplateBinding BorderBrush}"
                                               BorderThickness="{TemplateBinding BorderThickness}"
                                               CornerRadius="10">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="📊"
                                                         FontSize="32"
                                                         HorizontalAlignment="Center"
                                                         Margin="0,0,0,5"/>
                                                <TextBlock Text="Xem báo cáo"
                                                         FontSize="14"
                                                         Foreground="#263238"
                                                         HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <Border Background="White"
                   BorderBrush="#E0E0E0"
                   BorderThickness="1"
                   CornerRadius="10"
                   Padding="20"
                   Margin="0,30,0,0">
                <StackPanel>
                    <TextBlock Text="Thông tin hệ thống"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="#263238"
                              Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                  Text="Phiên bản:"
                                  FontWeight="SemiBold"
                                  Margin="0,0,10,10"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                  Text="1.0.0"
                                  Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                  Text="Ngày cập nhật:"
                                  FontWeight="SemiBold"
                                  Margin="0,0,10,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                  Text="12/11/2025"
                                  Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                  Text="Trạng thái kết nối:"
                                  FontWeight="SemiBold"
                                  Margin="0,0,10,0"/>
                        <StackPanel Grid.Row="2" Grid.Column="1"
                                   Orientation="Horizontal">
                            <Ellipse Width="10" Height="10"
                                    Fill="#4CAF50"
                                    Margin="0,0,5,0"/>
                            <TextBlock Text="Kết nối thành công"
                                      Foreground="#4CAF50"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
