@{
}
@model LibraryWeb.Models.SearchResultViewModel
@{
    ViewData["Title"] = "Danh sách sách";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2><i class="bi bi-book"></i> Danh sách sách</h2>
            <p class="text-muted">
                Tìm thấy <strong>@Model.Pagination.TotalItems</strong> cuốn sách
            </p>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" id="searchForm">

                <div class="row mb-3">
                    <div class="col-md-12">
                        <div class="input-group input-group-lg">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" name="SearchQuery" class="form-control"
                                   placeholder="Tìm kiếm theo tên sách..."
                                   value="@Model.Filters.SearchQuery">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-search"></i> Tìm kiếm
                            </button>
                        </div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-person"></i> Tác giả
                        </label>
                        <select name="AuthorId" class="form-select" onchange="this.form.submit()">
                            @if (Model.Filters.Authors != null)
                            {
                                @foreach (var item in Model.Filters.Authors)
                                {
                                    <option value="@item.Value" selected="@(item.Value == Model.Filters.AuthorId?.ToString())">
                                        @item.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-tag"></i> Thể loại
                        </label>
                        <select name="CategoryId" class="form-select" onchange="this.form.submit()">
                            @if (Model.Filters.Categories != null)
                            {
                                @foreach (var item in Model.Filters.Categories)
                                {
                                    <option value="@item.Value" selected="@(item.Value == Model.Filters.CategoryId?.ToString())">
                                        @item.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-translate"></i> Ngôn ngữ
                        </label>
                        <select name="Language" class="form-select" onchange="this.form.submit()">
                            @if (Model.Filters.Languages != null)
                            {
                                @foreach (var item in Model.Filters.Languages)
                                {
                                    <option value="@item.Value" selected="@(item.Value == Model.Filters.Language)">
                                        @item.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-sort-down"></i> Sắp xếp
                        </label>
                        <select name="SortBy" class="form-select" onchange="this.form.submit()">
                            <option value="title" selected="@(Model.Filters.SortBy == "title")">Tên sách (A-Z)</option>
                            <option value="year" selected="@(Model.Filters.SortBy == "year")">Năm xuất bản</option>
                        </select>
                        <input type="hidden" name="SortOrder" value="@Model.Filters.SortOrder" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Filters.SearchQuery) ||
                                Model.Filters.AuthorId.HasValue ||
                                Model.Filters.CategoryId.HasValue ||
                                !string.IsNullOrEmpty(Model.Filters.Language))
                {
                    <div class="row mt-3">
                        <div class="col-md-12 text-end">
                            <a asp-action="Index" class="btn btn-outline-danger">
                                <i class="bi bi-x-circle"></i> Xóa bộ lọc
                            </a>
                        </div>
                    </div>
                }

                <input type="hidden" name="Page" value="1" />
                <input type="hidden" name="PageSize" value="@Model.Pagination.PageSize" />
            </form>
        </div>
    </div>


    @if (!string.IsNullOrEmpty(Model.Filters.SearchQuery) ||
        Model.Filters.AuthorId.HasValue ||
        Model.Filters.CategoryId.HasValue ||
        !string.IsNullOrEmpty(Model.Filters.Language))
    {
        <div class="mb-3">
            <strong>Đang lọc theo:</strong>

            @if (!string.IsNullOrEmpty(Model.Filters.SearchQuery))
            {
                <span class="badge bg-primary me-1 py-2 px-3">
                    <i class="bi bi-search"></i> "@Model.Filters.SearchQuery"
                    <a href="#" onclick="removeFilter('SearchQuery')" class="text-white ms-2" style="text-decoration: none; font-size: 18px;">×</a>
                </span>
            }

            @if (Model.Filters.AuthorId.HasValue)
            {
                var authorName = Model.Filters.Authors?.FirstOrDefault(a => a.Value == Model.Filters.AuthorId.ToString())?.Text;
                <span class="badge bg-info me-1 py-2 px-3">
                    <i class="bi bi-person"></i> @authorName
                    <a href="#" onclick="removeFilter('AuthorId')" class="text-white ms-2" style="text-decoration: none; font-size: 18px;">×</a>
                </span>
            }

            @if (Model.Filters.CategoryId.HasValue)
            {
                var categoryName = Model.Filters.Categories?.FirstOrDefault(c => c.Value == Model.Filters.CategoryId.ToString())?.Text;
                <span class="badge bg-success me-1 py-2 px-3">
                    <i class="bi bi-tag"></i> @categoryName
                    <a href="#" onclick="removeFilter('CategoryId')" class="text-white ms-2" style="text-decoration: none; font-size: 18px;">×</a>
                </span>
            }

            @if (!string.IsNullOrEmpty(Model.Filters.Language))
            {
                <span class="badge bg-warning text-dark me-1 py-2 px-3">
                    <i class="bi bi-translate"></i> @Model.Filters.Language
                    <a href="#" onclick="removeFilter('Language')" class="text-dark ms-2" style="text-decoration: none; font-size: 18px;">×</a>
                </span>
            }
        </div>
    }

    @if (Model.Books.Any())
    {
        <div class="row">
            @foreach (var book in Model.Books)
            {
                @* <a href="/Books/Details/@book.BookId"> *@
                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                    <div class="card h-100 shadow-sm book-card">
                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                        {
                            var imageUrl = ImageUrlHelper.GetFullImageUrl(book.ImageUrl);
                            <img src="@imageUrl" class="card-img-top" alt="@book.Title"
                                 style="height: 250px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center"
                                 style="height: 250px;">
                                <i class="bi bi-book fs-1 text-white"></i>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title" style="min-height: 48px; line-height: 1.4;">
                                <a asp-action="Details" asp-route-id="@book.BookId"
                                   class="text-decoration-none text-dark"
                                   title="@book.Title">
                                    @(book.Title.Length > 50 ? book.Title.Substring(0, 50) + "..." : book.Title)
                                </a>
                            </h6>

                            @if (!string.IsNullOrEmpty(book.PublisherName))
                            {
                                <p class="card-text text-muted small mb-1">
                                    <i class="bi bi-building"></i> @book.PublisherName
                                </p>
                            }

                            @if (book.PublicationYear.HasValue)
                            {
                                <p class="card-text text-muted small mb-2">
                                    <i class="bi bi-calendar"></i> @book.PublicationYear
                                </p>
                            }

                            <div class="mt-auto">
                                @if (book.Price.HasValue)
                                {
                                    <p class="text-primary fw-bold mb-2">@book.Price.Value.ToString("N0")đ</p>
                                }

                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted">
                                        <i class="bi bi-bookmark"></i> Còn: @book.AvailableQuantity/@book.TotalQuantity
                                    </small>

                                    @if (book.AvailableQuantity > 0)
                                    {
                                        <span class="badge bg-success">Còn sách</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Hết sách</span>
                                    }
                                </div>

                                <a asp-action="Details" asp-route-id="@book.BookId"
                                   class="btn btn-outline-primary btn-sm w-100">
                                    <i class="bi bi-eye"></i> Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                @* </a> *@
            }
        </div>
  
        @if (Model.Pagination.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(!Model.Pagination.HasPrevious ? "disabled" : "")">
                        <a class="page-link" href="#" onclick="goToPage(@(Model.Pagination.CurrentPage - 1))">
                            <i class="bi bi-chevron-left"></i> Trước
                        </a>
                    </li>

                    @{
                        var startPage = Math.Max(1, Model.Pagination.CurrentPage - 2);
                        var endPage = Math.Min(Model.Pagination.TotalPages, Model.Pagination.CurrentPage + 2);
                    }

                    @if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="#" onclick="goToPage(1)">1</a>
                        </li>
                        @if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    @for (var i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == Model.Pagination.CurrentPage ? "active" : "")">
                            <a class="page-link" href="#" onclick="goToPage(@i)">@i</a>
                        </li>
                    }

                    @if (endPage < Model.Pagination.TotalPages)
                    {
                        @if (endPage < Model.Pagination.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="#" onclick="goToPage(@Model.Pagination.TotalPages)">
                                @Model.Pagination.TotalPages
                            </a>
                        </li>
                    }

                    <!-- Next -->
                    <li class="page-item @(!Model.Pagination.HasNext ? "disabled" : "")">
                        <a class="page-link" href="#" onclick="goToPage(@(Model.Pagination.CurrentPage + 1))">
                            Sau <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="text-center text-muted mb-4">
                Trang @Model.Pagination.CurrentPage / @Model.Pagination.TotalPages
                (@Model.Pagination.TotalItems kết quả)
            </div>
        }
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-info-circle fs-1 d-block mb-3"></i>
            <h5>Không tìm thấy sách nào!</h5>
            <p class="mb-3">Vui lòng thử lại với từ khóa hoặc bộ lọc khác.</p>
            <a asp-action="Index" class="btn btn-primary">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function goToPage(page) {
            event.preventDefault();
            const form = document.getElementById('searchForm');
            form.querySelector('input[name="Page"]').value = page;
            form.submit();
        }

        function removeFilter(filterName) {
            event.preventDefault();
            const form = document.getElementById('searchForm');
            const input = form.querySelector(`[name="${filterName}"]`);
            if (input) {
                input.value = '';
            }
            form.submit();
        }

        // Add hover effect to book cards
        document.querySelectorAll('.book-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-5px)';
                this.style.transition = 'transform 0.3s';
            });
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
            });
        });
    </script>
}

@section Styles {
    <style>
        .book-card {
            transition: transform 0.3s, box-shadow 0.3s;
        }

            .book-card:hover {
                box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
            }
    </style>
}