@model LibraryWeb.Models.BookDetailViewModel
@{
    ViewData["Title"] = Model.Title;
    var imageUrl = ImageUrlHelper.GetFullImageUrl(Model.ImageUrl);
}
<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Danh sách sách</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                @if (!string.IsNullOrEmpty(imageUrl))
                {
                    <img src="@imageUrl" class="card-img-top" alt="@Model.Title"
                         style="height: 500px; object-fit: cover;">
                }
                else
                {
                    <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center"
                         style="height: 500px;">
                        <i class="bi bi-book text-white" style="font-size: 100px;"></i>
                    </div>
                }

                <div class="card-body text-center">
                    @if (Model.AvailableQuantity > 0)
                    {
                        <div class="alert alert-success mb-3">
                            <i class="bi bi-check-circle"></i>
                            <strong>Còn @Model.AvailableQuantity/@Model.TotalQuantity cuốn</strong>
                        </div>

                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <a asp-controller="Borrowing" asp-action="Create" asp-route-bookId="@Model.BookId"
                               class="btn btn-success btn-lg w-100">
                                <i class="bi bi-bookmark-plus"></i> Mượn sách ngay
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Auth" asp-action="Login"
                               class="btn btn-primary btn-lg w-100">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập để mượn
                            </a>
                        }
                    }
                    else
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-x-circle"></i> <strong>Hết sách</strong>
                        </div>
                        <button class="btn btn-secondary btn-lg w-100" disabled>
                            <i class="bi bi-x-circle"></i> Không thể mượn
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="card-title mb-3">
                        <i class="bi bi-book-fill text-primary"></i> @Model.Title
                    </h2>

                    @if (Model.Authors is not null)
                    {
                         <i class="bi bi-person"></i> <strong>Tác giả:</strong>
                        var authorsList = Model.Authors.ToList();
                        for (int i = 0; i < authorsList.Count; i++)
                        {
                            var authorViewModel = authorsList[i];
                            var separator = i < authorsList.Count - 1 ? ", " : "";
                            <a href="/Books?SearchQuery=&AuthorId=@authorViewModel.AuthorId&CategoryId=&Language=&SortBy=title&SortOrder=asc&Page=1&PageSize=12" class="lead text-muted mb-3 text-decoration-none">
                                @(authorViewModel.AuthorName + separator)
                            </a>
                            
                        }
                        
                    }

                    <hr>

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">
                            <i class="bi bi-upc-scan"></i> ISBN:
                        </div>
                        <div class="col-sm-8">
                            <code class="fs-6">@Model.Isbn</code>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">
                            <i class="bi bi-tag"></i> Thể loại:
                        </div>
                        <div class="col-sm-8">
                            @if (Model.Categories is not null)
                            {
                                foreach (CategoryViewModel categoryViewModel in Model.Categories )
                                {
                                    <a href="/Books?SearchQuery=&AuthorId=&CategoryId=@categoryViewModel.CategoryId&Language=&SortBy=title&SortOrder=asc&Page=1&PageSize=12" class="badge bg-primary text-decoration-none">@(categoryViewModel.CategoryName)</a>
                                }

                            }    
                            
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.PublisherName))
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4 fw-bold">
                                <i class="bi bi-building"></i> Nhà xuất bản:
                            </div>
                            <div class="col-sm-8">
                                @Model.PublisherName
                            </div>
                        </div>
                    }

                    @if (Model.PublicationYear.HasValue)
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4 fw-bold">
                                <i class="bi bi-calendar-event"></i> Năm xuất bản:
                            </div>
                            <div class="col-sm-8">
                                @Model.PublicationYear
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Language))
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4 fw-bold">
                                <i class="bi bi-translate"></i> Ngôn ngữ:
                            </div>
                            <div class="col-sm-8">
                                @Model.Language
                            </div>
                        </div>
                    }

                    @if (Model.PageCount.HasValue && Model.PageCount > 0)
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4 fw-bold">
                                <i class="bi bi-file-text"></i> Số trang:
                            </div>
                            <div class="col-sm-8">
                                @Model.PageCount trang
                            </div>
                        </div>
                    }

                    @if (Model.Price.HasValue)
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4 fw-bold">
                                <i class="bi bi-cash"></i> Giá sách:
                            </div>
                            <div class="col-sm-8">
                                <span class="text-danger fs-5 fw-bold">@Model.Price.Value.ToString("N0")đ</span>
                            </div>
                        </div>
                    }

                    <hr>

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">
                            <i class="bi bi-stack"></i> Tình trạng:
                        </div>
                        <div class="col-sm-8">
                            <div class="d-flex align-items-center gap-2">
                                @if (Model.AvailableQuantity > 0)
                                {
                                    <span class="badge bg-success fs-6">Còn sách</span>
                                    <span class="text-muted">(@Model.AvailableQuantity/@Model.TotalQuantity cuốn)</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">Hết sách</span>
                                    <span class="text-muted">(0/@Model.TotalQuantity cuốn)</span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4 fw-bold">
                                <i class="bi bi-geo-alt"></i> Vị trí:
                            </div>
                            <div class="col-sm-8">
                                <span class="badge bg-info text-dark">@Model.Location</span>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <hr>
                        <div class="mb-3">
                            <h5 class="mb-3">
                                <i class="bi bi-card-text"></i> Mô tả:
                            </h5>
                            <p class="text-justify">@Model.Description</p>
                        </div>
                    }

                    @if (Model.CreatedAt.HasValue || Model.UpdatedAt.HasValue)
                    {
                        <hr>
                        <div class="text-muted small">
                            @if (Model.CreatedAt.HasValue)
                            {
                                <div>
                                    <i class="bi bi-clock"></i> Thêm vào thư viện:
                                    <strong>@Model.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            }
                            @if (Model.UpdatedAt.HasValue && Model.UpdatedAt != Model.CreatedAt)
                            {
                                <div>
                                    <i class="bi bi-arrow-repeat"></i> Cập nhật lần cuối:
                                    <strong>@Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <a asp-action="Index" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-arrow-left"></i> Quay lại danh sách
                            </a>
                        </div>
                        <div class="col-md-6">
                            @if (Model.AvailableQuantity > 0)
                            {
                                @if (Context.Session.GetInt32("UserId") != null)
                                {
                                    <a asp-controller="Borrowing" asp-action="Create" asp-route-bookId="@Model.BookId"
                                       class="btn btn-success w-100">
                                        <i class="bi bi-bookmark-plus"></i> Mượn sách
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Auth" asp-action="Login"
                                       class="btn btn-primary w-100">
                                        <i class="bi bi-box-arrow-in-right"></i> Đăng nhập để mượn
                                    </a>
                                }
                            }
                            else
                            {
                                <button class="btn btn-secondary w-100" disabled>
                                    <i class="bi bi-x-circle"></i> Hết sách
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* 
            @if (Model.BorrowCount.HasValue && Model.BorrowCount > 0)
            {
                <div class="card shadow-sm mt-3">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-graph-up"></i> Thống kê
                        </h5>
                        <div class="row text-center">
                            <div class="col-md-6">
                                <div class="p-3 bg-light rounded">
                                    <i class="bi bi-people-fill text-primary fs-3"></i>
                                    <div class="mt-2">
                                        <strong class="fs-4">@Model.BorrowCount</strong>
                                        <div class="text-muted small">Lượt mượn</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 bg-light rounded">
                                    <i class="bi bi-star-fill text-warning fs-3"></i>
                                    <div class="mt-2">
                                        <strong class="fs-4">Phổ biến</strong>
                                        <div class="text-muted small">Top sách mượn nhiều</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            } *@
        </div>
    </div>

    <!-- Sách liên quan (optional) -->
    <div class="row mt-5">
        <div class="col-12">
            <h4 class="mb-3">
                <i class="bi bi-collection"></i> Sách cùng thể loại
            </h4>
            <p class="text-muted">
                <i class="bi bi-arrow-right"></i>
                @if (Model.Categories is not null)
                {
                    foreach (CategoryViewModel categoryViewModel in Model.Categories)
                    {
                        <span>
                        <a asp-action="Category/@categoryViewModel.CategoryId" asp-route-category="@categoryViewModel.CategoryName" class="text-decoration-none">
                            Xem tất cả sách @categoryViewModel.CategoryName
                        </a>
                        </span>
                    }
                }               
            </p>
        </div>
    </div>
</div>